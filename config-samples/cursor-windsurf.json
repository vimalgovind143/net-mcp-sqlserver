{
  "mcpServers": {
    "sqlserver": {
      "command": "dotnet",
      "args": ["/absolute/path/to/SqlServerMcpServer/bin/Debug/net10.0/win-x64/SqlServerMcpServer.dll"],
      "env": {
        "MCP_TRANSPORT": "stdio",
        "SQLSERVER_CONNECTION_STRING": "Server=localhost,1433;Database=master;User Id=sa;Password=YourPass!;TrustServerCertificate=true;"
      },
      "disabled": false,
      "autoApprove": [
        "get_connections",
        "switch_connection",
        "get_server_health",
        "get_current_database",
        "get_databases",
        "get_tables",
        "get_table_schema",
        "get_stored_procedures",
        "get_object_definition",
        "read_query"
      ]
    }
  }
}
