# MCP Server
MCP_TRANSPORT=sse
MCP_PORT=8080
MCP_SERVER_NAME=SQL Server MCP
MCP_ENVIRONMENT=development

# SQL Server Connection
SQLSERVER_CONNECTION_STRING=Server=host.docker.internal,1433;Database=master;User Id=sa;Password=YourPass!;TrustServerCertificate=true;
SQLSERVER_COMMAND_TIMEOUT=30

# Cache TTLs (seconds)
CACHE_TTL_METADATA_SECONDS=300
CACHE_TTL_SCHEMA_SECONDS=600
CACHE_TTL_PROCEDURE_SECONDS=300
